{
  "name": "siokit-client",
  "version": "0.1.2",
  "description": "Socket.IO-compatible client — WebSocket transport with typed emit/on/emitWithAck and binary support",
  "keywords": [
    "socket.io",
    "client",
    "websocket",
    "real-time",
    "browser",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rolldown -c && tsc -p tsconfig.build.json && find dist -name '*.d.ts' -exec sed -i \"s/\\.ts'/\\.js'/g\" {} +",
    "prepublishOnly": "bun run build &&   cp ../../LICENSE . 2>/dev/null"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nahida-aa/siokit.git"
  },
  "dependencies": {
    "siokit-core": "^0.1.2",
    "siokit-parser": "^0.1.2"
  }
}
