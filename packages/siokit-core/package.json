{
  "name": "siokit-core",
  "version": "0.1.0",
  "description": "Core types and event bus for siokit — the Socket.IO-compatible library",
  "keywords": [
    "socket.io",
    "websocket",
    "real-time",
    "event-bus",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rolldown -c && tsc -p tsconfig.build.json && find dist -name '*.d.ts' -exec sed -i \"s/\\.ts'/\\.js'/g\" {} +",
    "prepublishOnly": "bun run build && cp ../../LICENSE . 2>/dev/null"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nahida-aa/siokit.git"
  }
}
